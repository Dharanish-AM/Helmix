# Editors & IDEs
# ==============================================================
# JetBrains
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# VS Code — keep settings.json (project-wide file associations)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Emacs
\#*\#
.#*

# ==============================================================
# Environment & Secrets
# ==============================================================
.env
.env.*
!.env.example
*.local

# JWT keys generated by scripts/generate-jwt-keys.sh
certs/

# ==============================================================
# Go  (go.work / multi-module workspace)
# ==============================================================
# Compiled service & CLI binaries
bin/
dist/

# Test binaries produced by `go test -c`
*.test

# Coverage
cover.out
coverage.out
*.coverprofile
**/coverage/

# Profiling artefacts
*.prof
*.pprof

# ==============================================================
# Node.js / npm / Next.js / Turbo
# ==============================================================
**/node_modules/
**/.next/
**/out/
**/.turbo/
**/.cache/
**/*.tsbuildinfo

# Debug / error logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ESLint cache
.eslintcache

# Vitest cache
**/.vitest-cache/

# ==============================================================
# Python  (services/incident-ai — FastAPI / pytest / qdrant)
# ==============================================================
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd

# Virtual environments (root .venv and per-service)
.venv/
venv/
**/.venv/
**/venv/
*.venv

# pytest / coverage
**/.pytest_cache/
.coverage
.coverage.*
htmlcov/
**/htmlcov/

# Type checkers / linters
**/.mypy_cache/
**/.ruff_cache/
.dmypy.json
dmypy.json

# Distribution / packaging
**/*.egg-info/
**/build/

# ==============================================================
# Docker
# ==============================================================
# Local override file (never commit credentials or port changes)
docker-compose.override.yml

# ==============================================================
# Kubernetes / Helm  (outputs from infra-generator)
# ==============================================================
# Local kubeconfig — never commit cluster credentials
kubeconfig
*.kubeconfig
**/.kube/

# ==============================================================
# Infrastructure data volumes  (local dev outside Docker)
# ==============================================================
# Terraform local working directories and plans
**/.terraform/
**/.terraform.lock.hcl
**/*.tfstate
**/*.tfstate.*
**/*.tfplan

# NATS JetStream file-based storage
jetstream/

# Qdrant vector-DB local storage (incident-ai)
qdrant_storage/

# ==============================================================
# Test artefacts
# ==============================================================
tests/load/results/
**/test-results/
**/testresults/

# ==============================================================
# Logs & temp files
# ==============================================================
*.log
logs/
tmp/
temp/
*.tmp
*.pid
*.seed
*.bak
*.orig
