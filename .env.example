# Auth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JWT_PRIVATE_KEY_PATH=./certs/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./certs/jwt-public.pem

# Database and Cache
DATABASE_URL=postgres://helmix:helmix@localhost:5432/helmix?sslmode=disable
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# Kubernetes
KUBECONFIG=~/.kube/config
HELMIX_NAMESPACE=helmix-system

# AI and LLM
HELMIX_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=helmix-incidents

# Container Registry
REGISTRY_URL=ghcr.io/your-org
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686
